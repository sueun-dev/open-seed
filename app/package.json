{
  "name": "open-seed",
  "version": "0.1.0",
  "description": "Open Seed | Autonomous AGI Coding Engine",
  "author": "sueun-dev",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "node server.js",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.openseed.app",
    "productName": "Open Seed",
    "directories": { "output": "../release" },
    "files": ["main.js", "preload.js", "server.js", "index.html", "package.json"],
    "asarUnpack": ["server.js"],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [{"target": "dir"}],
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  }
}
