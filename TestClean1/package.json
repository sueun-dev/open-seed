{
  "name": "neon-snake-game",
  "version": "1.0.0",
  "description": "Neon-styled Snake game with HTML5 Canvas, Web Audio API SFX, progressive difficulty",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server . -p 8080 -o index.html",
    "build": "node -e \"const fs=require('fs');const p=require('path');const d=p.join(__dirname,'dist');if(!fs.existsSync(d))fs.mkdirSync(d);fs.copyFileSync('index.html',p.join(d,'index.html'));console.log('Build complete: dist/index.html');\"",
    "test": "node test.js"
  },
  "keywords": ["snake", "game", "neon", "canvas"],
  "license": "MIT"
}
